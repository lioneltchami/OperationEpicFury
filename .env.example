# ============================================================
# Operation Epic Fury - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# DEPLOYMENT CHECKLIST:
# 1. Set up Upstash Redis     -> https://console.upstash.com
# 2. Deploy to Vercel          -> vercel
# 3. Add env vars in Vercel    -> Settings > Environment Variables
# 4. Set Telegram webhook      -> see TELEGRAM section below
# 5. Add GitHub secrets        -> see GITHUB ACTIONS section below
# 6. Point your domain         -> Vercel > Settings > Domains
# ============================================================


# ── 1. DATABASE (Upstash Redis) ─────────────────────────────
# Create a free Redis database at https://console.upstash.com
# Copy the Redis URL (starts with redis:// or rediss://)
KV_REDIS_URL=


# ── 2. ADMIN DASHBOARD ──────────────────────────────────────
# Login credentials for /admin panel
# CHANGE THESE from defaults before deploying!
ADMIN_PASSWORD=
PUBLISH_SECRET=


# ── 3. SITE CONFIGURATION ───────────────────────────────────
# Your production domain (no trailing slash)
SITE_URL=https://epicfuryops.info
NEXT_PUBLIC_SITE_URL=https://epicfuryops.info

# GitHub repo URL shown in Hero + Footer (cosmetic)
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/FZ1010/OperationEpicFury


# ── 4. TELEGRAM BOT ─────────────────────────────────────────
# Create a bot via @BotFather on Telegram
# Bot token: given by BotFather after /newbot
TELEGRAM_BOT_TOKEN=

# Webhook secret: generate with `openssl rand -hex 32`
TELEGRAM_WEBHOOK_SECRET=

# Your Telegram user ID (get it by messaging @userinfobot)
# Comma-separated for multiple users (e.g. 123456789,987654321)
TELEGRAM_ALLOWED_USERS=

# Auto-monitor Telegram channels (optional)
# Comma-separated channel IDs (e.g. -1001234567890)
# Bot must be added as admin to these channels
TELEGRAM_ALLOWED_CHANNELS=

# AFTER DEPLOYING, register the webhook by running:
# curl "https://api.telegram.org/bot<YOUR_BOT_TOKEN>/setWebhook?url=https://epicfuryops.info/api/telegram/webhook&secret_token=<YOUR_WEBHOOK_SECRET>"


# ── 5. GITHUB ACTIONS (News Cron + Telegram Pipeline) ───────
# Required for: Telegram bot news processing + automated scraping
#
# GH_PAT: GitHub Personal Access Token with "repo" scope
#   Create at: https://github.com/settings/tokens/new
#   Select scope: "repo" (full control of private repositories)
GH_PAT=

# Your GitHub repo in "owner/repo" format
GITHUB_REPO=FZ1010/OperationEpicFury

# ALSO ADD THESE AS GITHUB REPO SECRETS (Settings > Secrets > Actions):
#   CLAUDE_CODE_OAUTH_TOKEN  -> needed for the news-cron.yml scraper
#
# AND THIS AS A GITHUB REPO VARIABLE (Settings > Variables > Actions):
#   SITE_URL = https://epicfuryops.info


# ── 6. WEB PUSH NOTIFICATIONS (Optional) ────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
# Users can subscribe to push notifications for breaking news
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
